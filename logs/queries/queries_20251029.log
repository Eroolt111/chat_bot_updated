  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_open_loans AS (     SELECT         acnt_code,         customer_name,         principal,         impairment_per,         cur_code,         txn_date,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail     WHERE status = 'O' )  SELECT     acnt_code,     customer_name,     principal,     impairment_per,     cur_code,     txn_date,     principal * (1 - COALESCE(impairment_per, 0) / 100) AS net_principal FROM latest_open_loans WHERE rn = 1 ORDER BY net_principal DESC;",
