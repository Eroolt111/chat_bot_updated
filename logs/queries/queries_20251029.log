  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_nonperforming_loans AS (     SELECT         acnt_code,         MAX(txn_date) AS latest_txn_date     FROM dbm.loan_balance_detail     WHERE         UPPER(class_name) IN (             UPPER('ХЭВИЙН БУС'), UPPER('ЭРГЭЛЗЭЭТЭЙ'), UPPER('МУУ')         )         AND status = 'O'     GROUP BY acnt_code ),  latest_balances AS (     SELECT         lbd.acnt_code,         lbd.customer_name,         lbd.acnt_name,         lbd.principal,         lbd.cur_code,         lbd.txn_date     FROM dbm.loan_balance_detail lbd     INNER JOIN latest_nonperforming_loans lnp         ON             lbd.acnt_code = lnp.acnt_code             AND lbd.txn_date = lnp.latest_txn_date     WHERE         UPPER(lbd.class_name) IN (             UPPER('ХЭВИЙН БУС'), UPPER('ЭРГЭЛЗЭЭТЭЙ'), UPPER('МУУ')         )         AND lbd.status = 'O' )  SELECT     cur_code,     SUM(principal) AS total_nonperforming_principal FROM latest_balances GROUP BY cur_code ORDER BY cur_code;",
  "result_count": 3,
  "final_answer": "Таны хүсэлтийн дагуу Хөгжлийн банкны чанаргүй зээлийн нийт үлдэгдлийг валют тус бүрээр харуулав:  - JPY: 1,217,560,548.19 - төгрөг: 701,899,131,774.98 - ам.доллар: 61,382,060.58  Хэрэв дэлгэрэнгүй мэдээлэл хэрэгтэй бол нэмэлтээр асуугаарай."
