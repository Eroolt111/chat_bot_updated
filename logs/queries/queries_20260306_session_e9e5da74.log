  "original_query": "хамгийн сүүлд зээл авсан харилцагчийг харуул",
  "tables_count": 2,
  "tables_selected": [
    "dbm.loan_balance_detail",
    "dbm.loan_txn"
  ],
  "names_extracted_count": 40,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH latest_nrs AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_nrs_version     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code )  SELECT     n.customer_name,     t.acnt_code,     n.acnt_name,     t.txn_date AS adv_date,     t.txn_amount AS adv_amount,     t.cur_code FROM dbm.loan_txn t INNER JOIN latest_nrs l     ON t.acnt_code = l.acnt_code INNER JOIN dbm.bcom_nrs_detail n     ON t.acnt_code = n.acnt_code AND l.max_nrs_version = n.nrs_version WHERE t.txn_code = 'ADV' ORDER BY t.txn_date DESC FETCH FIRST 1 ROW ONLY;",
  "result_count": 1,
  "final_answer": "Хамгийн сүүлд зээл авсан харилцагчийн мэдээлэл:  - Харилцагчийн нэр: МОНГОЛ ГАЗРЫН ТОС БОЛОВСРУУЛАХ ҮЙЛДВЭР ТӨХХК - Дансны дугаар: MN050036003600009224 - Дансны нэр: МОНГОЛ ГАЗРЫН ТОС БОЛОВСРУУЛАХ ҮЙЛДВЭР ТӨХХК - Зээл авсан огноо: 2025-08-26 - Олгосон дүн: 331,573,389 төгрөг"
}
