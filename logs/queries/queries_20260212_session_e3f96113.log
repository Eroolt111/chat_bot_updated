  "names_extracted_count": 30,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH total_loan AS (     SELECT SUM(adv_amount * rate) AS total_loan_mnt     FROM dbm.loan_balance_detail     WHERE         txn_date = (SELECT MAX(txn_date) FROM dbm.loan_balance_detail)         AND adv_amount > 0 ),  r AS (     SELECT         cur_code,         MAX(rate) AS rate     FROM dbm.loan_balance_detail     WHERE txn_date = (SELECT MAX(txn_date) FROM dbm.loan_balance_detail)     GROUP BY cur_code ),  total_collateral AS (     SELECT SUM(limit_amt * rate) AS total_collateral_mnt     FROM dbm.coll_balance_detail c     INNER JOIN r ON c.cur_code = r.cur_code     WHERE         c.txn_date = (SELECT MAX(txn_date) FROM dbm.coll_balance_detail)         AND c.status = 'O'         AND c.limit_amt > 0 )  SELECT     t1.total_loan_mnt,     t2.total_collateral_mnt,     ROUND(t2.total_collateral_mnt / t1.total_loan_mnt, 2)         AS collateral_to_loan_ratio FROM total_loan t1, total_collateral t2;",
