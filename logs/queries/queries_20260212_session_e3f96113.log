  "was_decomposed": true,
  "final_sql": "WITH latest_loans AS (     SELECT         acnt_code,         customer_name,         acnt_name,         adv_amount,         cur_code     FROM dbm.loan_balance_detail     WHERE         txn_date = (SELECT MAX(txn_date) FROM dbm.loan_balance_detail)         AND adv_amount > 0 ),  latest_collateral AS (     SELECT         acnt_code AS coll_acnt_code,         name AS collateral_name,         cust_name,         limit_amt,         cur_code AS coll_cur_code,         loan_acnts     FROM dbm.coll_balance_detail     WHERE         txn_date = (SELECT MAX(txn_date) FROM dbm.coll_balance_detail)         AND status = 'O'         AND limit_amt > 0         AND loan_acnts IS NOT NULL )  SELECT     l.acnt_code AS loan_acnt_code,     l.customer_name,     l.acnt_name AS loan_name,     l.adv_amount,     l.cur_code AS loan_cur_code,     c.coll_acnt_code AS collateral_acnt_code,     c.collateral_name,     c.cust_name AS collateral_owner,     c.limit_amt AS collateral_limit_amt,     c.coll_cur_code AS collateral_cur_code,     ROUND(c.limit_amt / l.adv_amount, 2) AS collateral_to_loan_ratio FROM latest_loans l INNER JOIN latest_collateral c     ON ',' || c.loan_acnts || ',' LIKE '%,' || l.acnt_code || ',%' WHERE c.limit_amt >= l.adv_amount * 0.5 ORDER BY collateral_to_loan_ratio DESC, l.adv_amount DESC;",
