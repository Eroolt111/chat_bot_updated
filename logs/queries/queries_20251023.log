  "query_complexity": "SIMPLE",
  "final_sql": "WITH recent_customers AS (     SELECT customer_name     FROM dbm.loan_balance_detail     WHERE adv_date IS NOT NULL AND customer_name IS NOT NULL     GROUP BY customer_name     ORDER BY MAX(adv_date) DESC     FETCH FIRST 2 ROWS ONLY )  SELECT customer_name FROM recent_customers;",
  "result_count": 2,
  "final_answer": "Таны хүсэлтийн дагуу хамгийн сүүлийн хоёр зээлдэгчийн нэрийг танилцуулж байна:  1. МОНГОЛ ГАЗРЫН ТОС БОЛОВСРУУЛАХ ҮЙЛДВЭР ТӨХХК 2. ДОРНОД БҮСИЙН ЭРЧИМ ХҮЧНИЙ СИСТЕМ ТӨХК"
}
