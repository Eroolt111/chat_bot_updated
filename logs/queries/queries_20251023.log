  "was_decomposed": true,
  "final_sql": "SELECT   acnt_code,   MAX(customer_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS customer_name,   MAX(principal) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS principal,   MAX(impairment_per) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS impairment_per,   (MAX(principal) KEEP (DENSE_RANK LAST ORDER BY txn_date) * (1 - NVL(MAX(impairment_per) KEEP (DENSE_RANK LAST ORDER BY txn_date),0)/100)) AS principal_net,   MAX(cur_code) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS cur_code FROM dbm.loan_balance_detail WHERE status = 'O' GROUP BY acnt_code HAVING MAX(principal) KEEP (DENSE_RANK LAST ORDER BY txn_date) IS NOT NULL ORDER BY principal_net DESC;",
