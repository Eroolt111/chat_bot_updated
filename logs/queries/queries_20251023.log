  "names_extracted_count": 10,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH customer_max_loan AS (     SELECT          customer_name,          MAX(adv_amount) AS max_adv_amount,         MAX(cur_code) KEEP (DENSE_RANK FIRST ORDER BY adv_amount DESC) AS cur_code     FROM dbm.loan_balance_detail     WHERE adv_amount IS NOT NULL AND customer_name IS NOT NULL     GROUP BY customer_name ) SELECT customer_name, max_adv_amount, cur_code FROM customer_max_loan ORDER BY max_adv_amount DESC FETCH FIRST 5 ROWS ONLY;",
  "result_count": 5,
  "final_answer": "Таны хүсэлтийн дагуу Хөгжлийн банкнаас хамгийн өндөр зээл авсан 5 харилцагчийн мэдээллийг танилцуулж байна:  1. Нэр: ГОЛОМТ БАНК    - Зээлийн дүн: 269,030,318,200 MNT  2. Нэр: ДЦС-4 ТӨХК    - Зээлийн дүн: 260,093,860,509.44 MNT  3. Нэр: ЭРДЭНЭС МОНГОЛ ХХК    - Зээлийн дүн: 177,845,787,590.55 MNT  4. Нэр: ХУДАЛДАА ХӨГЖЛИЙН БАНК    - Зээлийн дүн: 125,000,000,000 MNT  5. Нэр: ЖИЖИГ ДУНД ҮЙЛДВЭРИЙГ ХӨГЖҮҮЛЭХ САН    - Зээлийн дүн: 100,117,000,000 MNT  Хэрэв илүү дэлгэрэнгүй мэдээлэл хэрэгтэй бол дахин асуугаарай."
}
