  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH latest_per_acnt AS (     SELECT         acnt_code,         cur_code,         principal,         class_name,         status,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail )  SELECT     cur_code,     SUM(principal) AS total_nonperforming_principal FROM latest_per_acnt WHERE     rn = 1     AND status = 'O'     AND (         UPPER(class_name) LIKE UPPER('%ЭРГЭЛЗЭЭТЭЙ%')         OR UPPER(class_name) LIKE UPPER('%МУУ%')     ) GROUP BY cur_code;",
