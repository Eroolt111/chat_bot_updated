  "final_sql": "SELECT      acnt_code,     MAX(customer_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS customer_name,     MAX(acnt_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS acnt_name,     MAX(principal) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS principal,     MAX(cur_code) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS cur_code,     MAX(class_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS class_name,     MAX(txn_date) AS txn_date FROM dbm.loan_balance_detail GROUP BY acnt_code HAVING UPPER(MAX(class_name) KEEP (DENSE_RANK LAST ORDER BY txn_date)) IN (UPPER('ХЭВИЙН БУС'), UPPER('ЭРГЭЛЗЭЭТЭЙ'), UPPER('МУУ'))    AND MAX(status) KEEP (DENSE_RANK LAST ORDER BY txn_date) = 'O';",
