  "names_extracted_count": 10,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH latest_principal AS (     SELECT         acnt_code,         customer_name,         cur_code,         principal,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail     WHERE principal IS NOT NULL )  SELECT     customer_name,     cur_code,     SUM(principal) AS total_principal FROM latest_principal WHERE     rn = 1     AND customer_name IS NOT NULL GROUP BY customer_name, cur_code ORDER BY total_principal DESC FETCH FIRST 5 ROWS ONLY;",
