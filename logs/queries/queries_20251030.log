  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH latest_open_loans AS (     SELECT         acnt_code,         account_manager_name,         principal,         rate,         principal * rate AS principal_in_mnt,         cur_code,         txn_date,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail     WHERE status = 'O'       AND principal IS NOT NULL       AND principal > 0 ) SELECT     account_manager_name,     SUM(principal_in_mnt) AS total_principal_in_mnt FROM latest_open_loans WHERE rn = 1 GROUP BY account_manager_name ORDER BY total_principal_in_mnt DESC NULLS LAST;",
