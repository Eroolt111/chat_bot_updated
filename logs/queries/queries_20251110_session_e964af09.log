  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_snapshot AS (     SELECT         acnt_code,         customer_name,         acnt_name,         principal,         cur_code,         rate,         status,         txn_date,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail     WHERE         principal IS NOT NULL         AND rate IS NOT NULL )  SELECT     acnt_code,     customer_name,     acnt_name,     principal,     cur_code,     status,     txn_date,     principal * rate AS principal_in_mnt FROM latest_snapshot WHERE rn = 1 ORDER BY principal_in_mnt DESC FETCH FIRST 1 ROW ONLY;",
  "result_count": 1,
  "final_answer": "Таны хүсэлтийн дагуу хамгийн өндөр зээлийн үлдэгдэлтэй зээлийн мэдээллийг хүргэж байна:  - Дансны код: MN780036003600008686 - Харилцагчийн нэр: ДЦС-4 ТӨХК - Дансны нэр: ДЦС-4 ТӨХК - Үлдэгдэл зээл: 253,309,397,578.54 төгрөг - Валют: төгрөг - Төлөв: O - Гүйлгээний огноо: 2025-09-12"
}
