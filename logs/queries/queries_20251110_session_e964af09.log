  "tables_count": 0,
  "tables_selected": [],
  "names_extracted_count": 20,
  "query_complexity": "COMPLEX",
  "was_decomposed": true,
  "final_sql": "WITH latest_per_account AS (     SELECT         acnt_code,         MAX(acnt_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS acnt_name,         MAX(customer_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS customer_name,         MAX(adv_date) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS adv_date,         MAX(end_date) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS end_date,         MAX(cur_code) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS cur_code,         MAX(status) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS status     FROM dbm.loan_balance_detail     WHERE status = 'O'       AND adv_date IS NOT NULL       AND end_date IS NOT NULL     GROUP BY acnt_code ), term_lengths AS (     SELECT         acnt_code,         acnt_name,         customer_name,         adv_date,         end_date,         cur_code,         status,         (end_date - adv_date) AS loan_term_days     FROM latest_per_account ), min_term AS (     SELECT MIN(loan_term_days) AS shortest_term     FROM term_lengths ) SELECT     acnt_code,     acnt_name,     customer_name,     adv_date,     end_date,     cur_code,     status,     loan_term_days FROM term_lengths WHERE loan_term_days = (SELECT shortest_term FROM min_term) ORDER BY loan_term_days ASC, acnt_code;",
  "result_count": 1,
  "final_answer": "Таны хүсэлтийн дагуу Монгол улсын Хөгжлийн Банкнаас хамгийн богино хугацаанд олгосон зээлийн мэдээллийг хүргэж байна:  - Дансны код: 3600005299 - Дансны нэр: МОНДУЛААН ТРЕЙД ХХК - Зээлдэгч: МОНДУЛААН ТРЕЙД ХХК - Олгосон огноо: 2018-12-28 - Дуусах огноо: 2019-12-03 - Валют: төгрөг - Статус: O - Зээлийн хугацаа (өдөр): 340"
