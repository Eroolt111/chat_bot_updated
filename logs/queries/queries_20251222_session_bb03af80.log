  "original_query": "[Chat History Summary] Хэрэглэгч хамгийн өндөр үлдэгдэлтэй зээлийн мэдээллийг авсан бөгөөд дараа нь ойрын 30 хоногт төлөгдөх хуваарьтай зээлүүдийн мэдээллийг хүссэн.  [Previous SQL (for reference - use exact column names and values from this)]: ```sql WITH latest_version_per_account AS (     SELECT         acnt_code,         MAX(nrs_version) AS current_version     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code )  SELECT     d.acnt_code,     d.customer_name,     d.schd_date,     d.amount,     d.int_amount,     d.theor_bal,     d.cur_code FROM dbm.bcom_nrs_detail d INNER JOIN latest_version_per_account lv     ON d.acnt_code = lv.acnt_code AND d.nrs_version = lv.current_version WHERE     d.status = 'O'     AND d.schd_date BETWEEN SYSDATE AND SYSDATE + 30 ORDER BY d.schd_date ASC; ```  [Current Question] Энэ онд төлөгдөх ёстой үлдсэн төлбөрийг харуул",
  "tables_count": 2,
  "tables_selected": [
    "dbm.bcom_nrs_detail",
    "dbm.loan_txn"
  ],
  "names_extracted_count": 25,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH latest_version_cte AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_ver     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code ),  scheduled_principal AS (     SELECT         t.cur_code,         SUM(t.amount) AS total_scheduled_principal     FROM dbm.bcom_nrs_detail t     INNER JOIN latest_version_cte lv         ON t.acnt_code = lv.acnt_code AND t.nrs_version = lv.max_ver     WHERE         t.status = 'O'         AND t.schd_date >= TRUNC(SYSDATE, 'YYYY')         AND t.schd_date <= LAST_DAY(ADD_MONTHS(TRUNC(SYSDATE, 'YYYY'), 11))     GROUP BY t.cur_code ),  paid_principal AS (     SELECT         cur_code,         SUM(txn_amount) AS total_paid_principal     FROM dbm.loan_txn     WHERE         txn_code = 'PAY_PRINC'         AND txn_date >= TRUNC(SYSDATE, 'YYYY')         AND txn_date <= LAST_DAY(ADD_MONTHS(TRUNC(SYSDATE, 'YYYY'), 11))     GROUP BY cur_code )  SELECT     s.cur_code,     COALESCE(s.total_scheduled_principal, 0) AS total_scheduled_principal,     COALESCE(p.total_paid_principal, 0) AS total_paid_principal,     COALESCE(s.total_scheduled_principal, 0)     - COALESCE(p.total_paid_principal, 0) AS remaining_principal_due FROM scheduled_principal s LEFT JOIN paid_principal p ON s.cur_code = p.cur_code ORDER BY s.cur_code;",
  "result_count": 4,
  "final_answer": "Энэ онд төлөгдөх ёстой үлдсэн төлбөрийн мэдээлэл:  - Юань:     - Төлөвлөгдсөн үндсэн төлбөр: 37,417,391.78     - Төлсөн үндсэн төлбөр: 8,237,762.84     - Үлдсэн төлбөр: 29,179,628.94  - Евро:     - Төлөвлөгдсөн үндсэн төлбөр: 11,750,000     - Төлсөн үндсэн төлбөр: 6,799,937.18     - Үлдсэн төлбөр: 4,950,062.82  - Иен:     - Төлөвлөгдсөн үндсэн төлбөр: 1,042,509,438.81     - Төлсөн үндсэн төлбөр: 578,819,562.34     - Үлдсэн төлбөр: 463,689,876.47  - Төгрөг:     - Төлөвлөгдсөн үндсэн төлбөр: 87,490,429,827.69     - Төлсөн үндсэн төлбөр: 13,364,728,989.81     - Үлдсэн төлбөр: 74,125,700,837.88"
}
