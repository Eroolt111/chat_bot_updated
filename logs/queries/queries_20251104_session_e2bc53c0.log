  "final_answer": "[{'user_question': 'Хамгийн өндөр олголттой 5 зээлдэгчийг харуул', 'sql_query': \"WITH latest_per_account AS ( SELECT acnt_code, cust_code, MAX(customer_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS customer_name, MAX(adv_date) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS adv_date, MAX(cur_code) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS cur_code, MAX(adv_amount) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS original_adv_amount, MAX(adv_amount * rate) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS adv_amount_in_mnt FROM dbm.loan_balance_detail WHERE adv_amount IS NOT NULL AND (acnt_name IS NOT NULL OR customer_name IS NOT NULL) GROUP BY acnt_code, cust_code HAVING MAX(adv_amount) KEEP (DENSE_RANK LAST ORDER BY txn_date) > 0 ), customer_totals AS ( SELECT cust_code, customer_name, SUM(adv_amount_in_mnt) AS total_adv_amount_in_mnt, LISTAGG(adv_date || ': ' || original_adv_amount || ' ' || cur_code || ' (' || adv_amount_in_mnt || ' MNT)', '; ') WITHIN GROUP (ORDER BY adv_date DESC) AS account_details FROM latest_per_account GROUP BY cust_code, customer_name ) SELECT cust_code, customer_name, total_adv_amount_in_mnt, account_details FROM customer_totals ORDER BY total_adv_amount_in_mnt DESC FETCH FIRST 3 ROWS ONLY;\"}, {'user_question': 'Ирэх 12 сарын хугацаанд төлөх ёстой нийт дүнг зээлдэгчийн нэрээр харуулна уу.', 'sql_query': \"WITH max_versions AS (SELECT acnt_code, MAX(nrs_version) AS latest_nrs_version FROM dbm.bcom_nrs_detail WHERE status = 'O' GROUP BY acnt_code) SELECT t.customer_name, SUM(t.amount + t.int_amount) AS total_due FROM dbm.bcom_nrs_detail t JOIN max_versions mv ON t.acnt_code = mv.acnt_code AND t.nrs_version = mv.latest_nrs_version WHERE t.status = 'O' AND t.schd_date >= SYSDATE AND t.schd_date < ADD_MONTHS(SYSDATE, 12) GROUP BY t.customer_name ORDER BY total_due DESC;\"}, {'user_question': 'Нийт чанаргүй зээлийн үлдэгдлийг харуул', 'sql_query': \"WITH latest_per_acnt AS (SELECT acnt_code, cur_code, principal, class_name, status, ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn FROM dbm.loan_balance_detail) SELECT cur_code, SUM(principal) AS total_nonperforming_principal FROM latest_per_acnt WHERE rn = 1 AND status = 'O' AND (UPPER(class_name) IN (UPPER('ХЭВИЙН БУС'), UPPER('ЭРГЭЛЗЭЭТЭЙ'), UPPER('МУУ'))) GROUP BY cur_code ORDER BY cur_code;\"}, {'user_question': 'Идэвхтэй зээлтэй зээлдэгчдийн тоо?', 'sql_query': \"WITH latest_status AS (SELECT acnt_code, customer_name, status, ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn FROM dbm.loan_balance_detail WHERE customer_name IS NOT NULL) SELECT COUNT(DISTINCT customer_name) AS active_borrower_count FROM latest_status WHERE rn = 1 AND status = 'O';\"}, {'user_question': 'Хамгийн сүүлийн хоёр зээлдэгчийн мэдээллийг харуулна уу?', 'sql_query': 'WITH recent_customers AS ( SELECT customer_name FROM DBM.LOAN_BALANCE_DETAIL WHERE adv_date IS NOT NULL AND customer_name IS NOT NULL GROUP BY customer_name ORDER BY MAX(adv_date) DESC FETCH FIRST 2 ROWS ONLY ), latest_advances AS ( SELECT t.customer_name, t.adv_amount, t.adv_date, ROW_NUMBER() OVER(PARTITION BY t.customer_name ORDER BY t.adv_date DESC, t.txn_date DESC) as rn FROM DBM.LOAN_BALANCE_DETAIL t JOIN recent_customers rc ON t.customer_name = rc.customer_name WHERE t.adv_date IS NOT NULL ) SELECT customer_name, adv_amount, adv_date FROM latest_advances WHERE rn = 1;'}]"
