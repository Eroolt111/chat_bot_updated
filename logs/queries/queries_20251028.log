  "was_decomposed": true,
  "final_sql": "WITH latest_per_account AS (     SELECT         acnt_code,         cust_code,         MAX(customer_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS customer_name,         MAX(adv_date) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS adv_date,         MAX(cur_code) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS cur_code,         MAX(adv_amount) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS original_adv_amount,         MAX(adv_amount * rate) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS adv_amount_in_mnt     FROM dbm.loan_balance_detail     WHERE adv_amount IS NOT NULL       AND (acnt_name IS NOT NULL OR customer_name IS NOT NULL)     GROUP BY acnt_code, cust_code     HAVING MAX(adv_amount) KEEP (DENSE_RANK LAST ORDER BY txn_date) > 0 ), customer_totals AS (     SELECT         cust_code,         customer_name,         SUM(adv_amount_in_mnt) AS total_adv_amount_in_mnt,         LISTAGG(adv_date || ': ' || original_adv_amount || ' ' || cur_code || ' (' || adv_amount_in_mnt || ' MNT)', '; ')              WITHIN GROUP (ORDER BY adv_date DESC) AS account_details     FROM latest_per_account     GROUP BY cust_code, customer_name ) SELECT     cust_code,     customer_name,     total_adv_amount_in_mnt,     account_details FROM customer_totals ORDER BY total_adv_amount_in_mnt DESC FETCH FIRST 3 ROWS ONLY;",
