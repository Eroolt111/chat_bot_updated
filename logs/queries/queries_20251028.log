  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH selected_accounts AS (     SELECT         acnt_name,         customer_name     FROM (         SELECT DISTINCT             acnt_name,             customer_name         FROM dbm.loan_balance_detail         WHERE acnt_name IN (             'НООЛУУР-ХААН БАНК ',             'НООЛУУР-УЛААНБААТАР ХОТЫН БАНК',             'ГОВЬ ХК',             'НООЛУУР-ХУДАЛДАА ХӨГЖЛИЙН БАНК',             'НООЛУУР-КАПИТАЛ БАНК',             'НООЛУУР - ХААН БАНК - 2017',             'НООЛУУР-ХАС БАНК',             'НООЛУУР - ГОЛОМТ БАНК',             'ЖИЖИГ ДУНД ҮЙЛДВЭРИЙГ ХӨГЖҮҮЛЭХ САН',             'НООЛУУР - ГОЛОМТ БАНК - 2017'         )     ) ),  latest_disbursements AS (     SELECT         t.acnt_name,         t.customer_name,         t.adv_amount,         t.cur_code,         t.adv_date,         ROW_NUMBER()             OVER (                 PARTITION BY t.acnt_name, t.customer_name                 ORDER BY t.adv_date DESC, t.txn_date DESC             )             AS rn     FROM dbm.loan_balance_detail t     INNER JOIN selected_accounts sa         ON t.acnt_name = sa.acnt_name AND t.customer_name = sa.customer_name     WHERE         t.adv_date IS NOT NULL         AND t.status = 'O' )  SELECT     acnt_name,     customer_name,     adv_amount,     cur_code,     adv_date FROM latest_disbursements WHERE rn = 1 ORDER BY adv_date DESC, acnt_name ASC;",
  "result_count": 0,
  "final_answer": "Таны хүсэлтийн дагуу дээрх дансуудад олгогдсон хэмжээний мэдээлэл олдсонгүй. Та шалган дахин асууж болно."
}
