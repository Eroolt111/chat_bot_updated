  "final_sql": "WITH pyramid_accounts AS (     SELECT DISTINCT acnt_code     FROM dbm.loan_balance_detail     WHERE customer_name = 'ПИРАМИД-ОРД ХХК' AND status = 'O' ),  latest_disbursement AS (     SELECT         t.acnt_code,         t.acnt_name,         t.customer_name,         t.adv_amount,         t.cur_code,         t.adv_date,         ROW_NUMBER()             OVER (                 PARTITION BY t.acnt_code                 ORDER BY t.adv_date DESC, t.txn_date DESC             )             AS rn     FROM dbm.loan_balance_detail t     INNER JOIN pyramid_accounts pa ON t.acnt_code = pa.acnt_code     WHERE t.adv_amount IS NOT NULL AND t.status = 'O' )  SELECT     acnt_code,     acnt_name,     customer_name,     adv_amount,     cur_code,     adv_date FROM latest_disbursement WHERE rn = 1 ORDER BY adv_date DESC;",
