  "final_sql": "WITH current_versions AS (     SELECT         acnt_code,         MAX(nrs_version) AS latest_nrs_version     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code ),  next_week_loans AS (     SELECT DISTINCT t.acnt_code     FROM dbm.bcom_nrs_detail t     INNER JOIN current_versions cv         ON t.acnt_code = cv.acnt_code AND t.nrs_version = cv.latest_nrs_version     WHERE         t.status = 'O'         AND t.schd_date >= TRUNC(SYSDATE)         AND t.schd_date < TRUNC(SYSDATE) + 7 ),  latest_per_acnt AS (     SELECT         l.acnt_code,         l.cust_code,         l.customer_name,         ROW_NUMBER()             OVER (PARTITION BY l.acnt_code ORDER BY l.txn_date DESC)             AS rn     FROM dbm.loan_balance_detail l     WHERE l.acnt_code IN (SELECT acnt_code FROM next_week_loans) )  SELECT     COUNT(DISTINCT customer_name) AS distinct_customer_count,     LISTAGG(DISTINCT customer_name, ', ') WITHIN GROUP (         ORDER BY customer_name     ) AS customer_names FROM latest_per_acnt WHERE rn = 1;",
