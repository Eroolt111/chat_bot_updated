  "status": "success",
  "original_query": "[Chat History Summary] Хэрэглэгч энэ онд төлөгдсөн нийт зээлийн төлөлт, төлөгдөх ёстой үлдсэн төлбөр, зөвхөн үндсэн төлбөрийн төлөлт болон энэ онд төлөгдөхөөр үлдсэн зээлийн төлөлтийн хуваарийг харуулах талаар SQL асуулга бичих хүсэлтүүд гаргасан.  [Previous SQL (for reference - use exact column names and values from this)]: ```sql WITH latest_version_cte AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_ver     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code )  SELECT     t.acnt_code,     t.customer_name,     t.cur_code,     t.schd_date,     t.amount AS principal_due,     t.int_amount AS interest_due FROM     dbm.bcom_nrs_detail t INNER JOIN latest_version_cte lv     ON         t.acnt_code = lv.acnt_code         AND t.nrs_version = lv.max_ver WHERE     t.status = 'O'     AND t.schd_date >= TRUNC(SYSDATE)     AND t.schd_date <= LAST_DAY(ADD_MONTHS(TRUNC(SYSDATE, 'YYYY'), 11)) ORDER BY     t.schd_date ASC, t.acnt_code ASC; ```  [Current Question] Энэ онд төлөгдөх ёстой нийт зээлийн үндсэн төлбөрөөс одоогийн байдлаар төлөгдсөн үндсэн төлбөрийг хасч харуул",
  "tables_count": 2,
  "tables_selected": [
    "dbm.bcom_nrs_detail",
    "dbm.loan_txn"
  ],
  "names_extracted_count": 25,
  "query_complexity": "COMPLEX",
  "was_decomposed": true,
  "final_sql": "WITH latest_version_cte AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_ver     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code ),  scheduled_principal AS (     SELECT         t.cur_code,         SUM(t.amount) AS total_scheduled_principal     FROM         dbm.bcom_nrs_detail t     INNER JOIN latest_version_cte lv         ON             t.acnt_code = lv.acnt_code             AND t.nrs_version = lv.max_ver     WHERE         t.status = 'O'         AND t.schd_date >= TRUNC(SYSDATE, 'YYYY')         AND t.schd_date <= LAST_DAY(ADD_MONTHS(TRUNC(SYSDATE, 'YYYY'), 11))     GROUP BY t.cur_code ),  paid_principal AS (     SELECT         cur_code,         SUM(txn_amount) AS total_paid_principal     FROM         dbm.loan_txn     WHERE         txn_code = 'PAY_PRINC'         AND txn_date >= TRUNC(SYSDATE, 'YYYY')         AND txn_date <= LAST_DAY(ADD_MONTHS(TRUNC(SYSDATE, 'YYYY'), 11))     GROUP BY cur_code )  SELECT     s.cur_code,     COALESCE(s.total_scheduled_principal, 0) AS total_scheduled_principal,     COALESCE(p.total_paid_principal, 0) AS total_paid_principal,     COALESCE(s.total_scheduled_principal, 0)     - COALESCE(p.total_paid_principal, 0) AS remaining_principal_due FROM     scheduled_principal s LEFT JOIN     paid_principal p     ON s.cur_code = p.cur_code ORDER BY     s.cur_code;",
  "result_count": 4,
  "final_answer": "Энэ онд төлөгдөх ёстой нийт зээлийн үндсэн төлбөрөөс одоогийн байдлаар төлөгдсөн үндсэн төлбөрийг хассан дүнг валют тус бүрээр харуулбал:  - Юань:     - Төлөгдөх ёстой нийт үндсэн төлбөр: 37,417,391.78     - Төлөгдсөн үндсэн төлбөр: 8,237,762.84     - Үлдэгдэл үндсэн төлбөр: 29,179,628.94  - Евро:     - Төлөгдөх ёстой нийт үндсэн төлбөр: 11,750,000     - Төлөгдсөн үндсэн төлбөр: 6,799,937.18     - Үлдэгдэл үндсэн төлбөр: 4,950,062.82  - Иен:     - Төлөгдөх ёстой нийт үндсэн төлбөр: 1,042,509,438.81     - Төлөгдсөн үндсэн төлбөр: 578,819,562.34     - Үлдэгдэл үндсэн төлбөр: 463,689,876.47  - Төгрөг:     - Төлөгдөх ёстой нийт үндсэн төлбөр: 87,490,429,827.69     - Төлөгдсөн үндсэн төлбөр: 13,364,728,989.81     - Үлдэгдэл үндсэн төлбөр: 74,125,700,837.88"
