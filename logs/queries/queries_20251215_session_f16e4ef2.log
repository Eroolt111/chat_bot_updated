  "was_decomposed": true,
  "final_sql": "WITH latest_version_cte AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_ver     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code ),  scheduled_2024 AS (     SELECT         t.acnt_code,         SUM(t.amount) AS scheduled_principal_2024     FROM dbm.bcom_nrs_detail t     INNER JOIN latest_version_cte lv         ON t.acnt_code = lv.acnt_code AND t.nrs_version = lv.max_ver     WHERE         t.status = 'O'         AND t.cur_code = 'MNT'         AND t.schd_date >= TO_DATE('2024-01-01', 'YYYY-MM-DD')         AND t.schd_date <= TO_DATE('2024-12-31', 'YYYY-MM-DD')     GROUP BY t.acnt_code ),  latest_balance AS (     SELECT         l.acnt_code,         l.principal AS current_principal     FROM dbm.loan_balance_detail l     WHERE         l.txn_date = (SELECT MAX(txn_date) FROM dbm.loan_balance_detail)         AND l.cur_code = 'MNT' )  SELECT     '2024 онд төлөгдөх ёстой нийт төгрөгийн зээлийн үндсэн төлбөрөөс төлөгдсөн дүн'         AS description,     SUM(         LEAST(             s.scheduled_principal_2024,             GREATEST(                 s.scheduled_principal_2024 - COALESCE(lb.current_principal, 0),                 0             )         )     ) AS total_principal_paid_mnt FROM scheduled_2024 s LEFT JOIN latest_balance lb     ON s.acnt_code = lb.acnt_code;",
  "result_count": 1,
  "final_answer": "2024 онд төлөгдөх ёстой нийт төгрөгийн зээлийн үндсэн төлбөрөөс одоогийн байдлаар төлөгдсөн дүн: 0.08 төгрөг байна."
