  "final_sql": "WITH first_disbursement AS (     SELECT         acnt_code,         cur_code AS original_currency,         adv_date,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY adv_date ASC) AS rn     FROM dbm.loan_balance_detail     WHERE         adv_date IS NOT NULL         AND adv_amount > 0         AND cur_code IS NOT NULL ),  foreign_balance_before_2020 AS (     SELECT acnt_code     FROM dbm.loan_balance_detail     WHERE         txn_date < TO_DATE('2020-01-01', 'YYYY-MM-DD')         AND principal > 0         AND cur_code IS NOT NULL         AND cur_code <> 'MNT'     GROUP BY acnt_code ),  latest_state AS (     SELECT         acnt_code,         customer_name,         acnt_name,         cur_code AS current_currency,         principal,         rate,         adv_date,         adv_amount,         status,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail     WHERE         cur_code IS NOT NULL         AND customer_name IS NOT NULL         AND acnt_name IS NOT NULL )  SELECT     l.customer_name,     l.acnt_name,     f.original_currency,     l.current_currency,     l.adv_date,     l.adv_amount,     l.principal,     l.rate,     (l.principal * l.rate) AS principal_in_mnt FROM first_disbursement f INNER JOIN latest_state l ON f.acnt_code = l.acnt_code INNER JOIN foreign_balance_before_2020 fb ON l.acnt_code = fb.acnt_code WHERE     f.rn = 1     AND l.rn = 1     AND f.original_currency <> 'MNT'     AND l.current_currency = 'MNT'     AND l.status = 'O'     AND l.principal > 0 ORDER BY (l.principal * l.rate) DESC;",
  "result_count": 0,
