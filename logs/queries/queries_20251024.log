  "final_sql": "WITH latest_per_acnt AS (     SELECT         acnt_code,         acnt_name,         customer_name,         principal,         cur_code,         rate,         txn_date,         status,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail     WHERE principal IS NOT NULL )  SELECT     acnt_code,     acnt_name,     customer_name,     principal,     cur_code,     rate,     (principal * rate) AS principal_in_mnt FROM latest_per_acnt WHERE     rn = 1     AND status = 'O' ORDER BY principal_in_mnt DESC FETCH FIRST 5 ROWS ONLY;",
