  "original_query": "Ирэх долоо хоногт төлөгдөа хуваарьтай зээлүүд байна уу?",
  "tables_count": 1,
  "tables_selected": [
    "dbm.bcom_nrs_detail"
  ],
  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_version_cte AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_ver     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code )  SELECT     t.acnt_code,     t.customer_name,     t.schd_date,     t.amount,     t.int_amount,     t.cur_code FROM dbm.bcom_nrs_detail t INNER JOIN latest_version_cte lv     ON t.acnt_code = lv.acnt_code AND t.nrs_version = lv.max_ver WHERE     t.status = 'O'     AND t.schd_date >= TRUNC(SYSDATE, 'IW') + 7     AND t.schd_date < TRUNC(SYSDATE, 'IW') + 14 ORDER BY t.schd_date ASC;",
