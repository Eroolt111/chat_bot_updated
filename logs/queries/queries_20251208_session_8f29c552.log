  "final_sql": "WITH most_recent_customer AS (     SELECT customer_name     FROM dbm.loan_balance_detail     WHERE         adv_date IS NOT NULL         AND customer_name IS NOT NULL     GROUP BY customer_name     ORDER BY MAX(adv_date) DESC     FETCH FIRST 1 ROW ONLY ),  customer_accounts AS (     SELECT         t.acnt_code,         t.customer_name,         ROW_NUMBER()             OVER (PARTITION BY t.acnt_code ORDER BY t.txn_date DESC)             AS rn     FROM dbm.loan_balance_detail t     WHERE         t.customer_name = (SELECT customer_name FROM most_recent_customer)         AND t.acnt_code IS NOT NULL )  SELECT     customer_name,     COUNT(*) AS num_loan_accounts FROM customer_accounts WHERE rn = 1 GROUP BY customer_name;",
