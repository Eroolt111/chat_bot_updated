  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_per_account AS (     SELECT          acnt_code,          cust_code,          MAX(customer_name) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS customer_name,         MAX(cur_code) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS cur_code,         MAX(principal) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS latest_principal,         MAX(rate) KEEP (DENSE_RANK LAST ORDER BY txn_date) AS latest_rate     FROM dbm.loan_balance_detail     WHERE status = 'O'     GROUP BY acnt_code, cust_code     HAVING MAX(principal) KEEP (DENSE_RANK LAST ORDER BY txn_date) > 0 ), customer_totals AS (     SELECT          cust_code,          customer_name,          SUM(latest_principal * latest_rate) AS total_balance_in_mnt,         LISTAGG(cur_code || ': ' || TO_CHAR(latest_principal, '9999999990.00'), '; ') WITHIN GROUP (ORDER BY cur_code) AS original_amounts_by_currency     FROM latest_per_account     GROUP BY cust_code, customer_name ) SELECT cust_code, customer_name, total_balance_in_mnt, original_amounts_by_currency FROM customer_totals ORDER BY total_balance_in_mnt DESC FETCH FIRST 1 ROW ONLY;",
  "result_count": 1,
  "final_answer": "Таны хүсэлтийн дагуу хамгийн их зээлийн үлдэгдэлтэй зээлдэгчийн мэдээллийг хүргэж байна:  - Харилцагчийн код: 9360000029 - Нэр: ДЦС-4 ТӨХК - Нийт зээлийн үлдэгдэл (төгрөгөөр): 253,309,397,578.54 - Валютын үлдэгдлүүд: MNT: ##############"
