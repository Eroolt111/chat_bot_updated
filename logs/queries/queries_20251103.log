  "final_sql": "WITH latest_per_acnt AS (     SELECT *     FROM (         SELECT             lbd.*,             ROW_NUMBER()                 OVER (PARTITION BY lbd.acnt_code ORDER BY lbd.txn_date DESC)                 AS rn         FROM dbm.loan_balance_detail lbd         WHERE             lbd.approv_amount IS NOT NULL             AND lbd.rate IS NOT NULL     )     WHERE rn = 1 )  SELECT     acnt_code,     customer_name,     acnt_name,     approv_amount,     cur_code,     status,     txn_date,     approv_amount * rate AS approv_amount_in_mnt FROM latest_per_acnt ORDER BY approv_amount_in_mnt DESC FETCH FIRST 1 ROW ONLY;",
