  "original_query": "Өнөөдөр төлөх хуваарьтай зээл байна уу?",
  "tables_count": 0,
  "tables_selected": [],
  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH max_versions AS (     SELECT         acnt_code,         MAX(nrs_version) AS latest_nrs_version     FROM dbm.bcom_nrs_detail     WHERE status = 'O'     GROUP BY acnt_code )  SELECT t.* FROM dbm.bcom_nrs_detail t INNER JOIN     max_versions mv     ON t.acnt_code = mv.acnt_code AND t.nrs_version = mv.latest_nrs_version WHERE     t.status = 'O'     AND t.schd_date = TRUNC(SYSDATE);",
  "result_count": 0,
  "final_answer": "Уучлаарай, өнөөдөр төлөх хуваарьтай зээл олдсонгүй."
}
