  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH filtered_loans AS (     SELECT         acnt_code,         customer_name,         acnt_name,         class_name,         principal,         cur_code,         status,         txn_date     FROM dbm.loan_balance_detail     WHERE         txn_date = (SELECT MAX(txn_date) FROM dbm.loan_balance_detail)         AND status = 'O'         AND principal > 0         AND class_name = 'ХЭВИЙН' )  SELECT     customer_name,     cur_code,     SUM(principal) AS total_principal,     COUNT(*) AS loan_count FROM filtered_loans GROUP BY customer_name, cur_code ORDER BY total_principal DESC;",
