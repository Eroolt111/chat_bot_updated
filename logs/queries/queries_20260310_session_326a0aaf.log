  "original_query": "show me the loans that should be repaid till 30 days from now",
  "tables_count": 1,
  "tables_selected": [
    "dbm.loan_balance_detail"
  ],
  "names_extracted_count": 40,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH latest_version_cte AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_ver     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code )  SELECT     t.acnt_code,     t.customer_name,     t.acnt_name,     t.schd_date,     t.amount AS principal_due,     t.int_amount AS interest_due,     t.cur_code FROM     dbm.bcom_nrs_detail t INNER JOIN latest_version_cte lv     ON t.acnt_code = lv.acnt_code AND t.nrs_version = lv.max_ver WHERE     t.status = 'O'     AND t.amount > 0     AND t.schd_date BETWEEN TRUNC(SYSDATE) AND TRUNC(SYSDATE) + 30 ORDER BY     t.schd_date ASC,     t.amount DESC;",
  "result_count": 5,
