  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH target_loan AS (     SELECT acnt_code     FROM dbm.loan_balance_detail     WHERE         class_name IN ('ХЭВИЙН', 'NORMAL')         AND adv_amount > 0         AND customer_name IS NOT NULL         AND acnt_name IS NOT NULL     ORDER BY (adv_amount * rate) DESC     FETCH FIRST 1 ROW ONLY )  SELECT     acnt_code,     customer_name,     acnt_name,     principal,     cur_code,     status,     txn_date FROM dbm.loan_balance_detail WHERE     acnt_code = (SELECT acnt_code FROM target_loan)     AND txn_date = (         SELECT MAX(txn_date) FROM dbm.loan_balance_detail         WHERE acnt_code = (SELECT acnt_code FROM target_loan)     )     AND status = 'O'     AND principal > 0;",
  "result_count": 0,
  "final_answer": "Мэдээлэл олдсонгүй."
}
