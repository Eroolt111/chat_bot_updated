{
  "session_id": "0df51f48",
  "timestamp": "2026-02-25T11:06:10.594601",
  "execution_time_seconds": 24.93,
  "llm_backend": "openai",
  "embedding_backend": "ollama",
  "status": "success",
  "original_query": "[Chat History Summary] Хөгжлийн банкны ашиг ажиллагааны үзүүлэлтийн талаарх мэдээллийг лавласан.  [Previous SQL (for reference - use exact column names and values from this)]: ```sql SELECT     gl_code,     gl_code_name,     cur_code,     SUM(balance) AS total_balance,     SUM(balance_ba) AS total_balance_mnt,     COUNT(*) AS acnt_count FROM     dbm.gl_balance_detail WHERE     txn_date = (SELECT MAX(txn_date) FROM dbm.gl_balance_detail)     AND status = 1 GROUP BY     gl_code, gl_code_name, cur_code ORDER BY     gl_code,     SUM(balance_ba) DESC; ```  [Current Question] Хөгжлийн банкны 2024 оны нийт ашиг хэд байсан бэ?",
  "tables_count": 1,
  "tables_selected": [
    "dbm.gl_balance_detail"
  ],
  "names_extracted_count": 40,
  "query_complexity": "SIMPLE",
  "final_sql": "WITH profit_loss AS (     SELECT         gl_code_name,         cur_code,         SUM(balance) AS total_balance,         SUM(balance_ba) AS total_balance_mnt     FROM         dbm.gl_balance_detail     WHERE         txn_date = (             SELECT MAX(txn_date)             FROM dbm.gl_balance_detail             WHERE EXTRACT(YEAR FROM txn_date) = 2024         )         AND status = 1         AND gl_code_name IN ('ОРЛОГО', 'ЗАРДАЛ')     GROUP BY         gl_code_name, cur_code ),  pl_expense AS (     SELECT         cur_code,         total_balance_mnt     FROM profit_loss     WHERE gl_code_name = 'ЗАРДАЛ' )  SELECT     '2024 оны нийт ашиг' AS description,     pl_income.cur_code,     COALESCE(pl_income.total_balance_mnt, 0)     - COALESCE(pl_expense.total_balance_mnt, 0) AS profit_mnt FROM     (         SELECT             cur_code,             total_balance_mnt         FROM profit_loss         WHERE gl_code_name = 'ОРЛОГО'     ) pl_income FULL OUTER JOIN     pl_expense     ON pl_income.cur_code = pl_expense.cur_code ORDER BY     profit_mnt DESC;",
  "result_count": 0,
  "final_answer": "Мэдээлэл олдсонгүй."
}
