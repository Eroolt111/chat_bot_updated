  "was_decomposed": true,
  "final_sql": "SELECT     customer_name,     COUNT(DISTINCT acnt_code) AS loan_count FROM dbm.loan_balance_detail WHERE     txn_date = (SELECT MAX(txn_date) FROM dbm.loan_balance_detail)     AND UPPER(customer_name) LIKE '%ЭРЧИМ ХҮЧНИЙ ЯАМ%'     AND status = 'O'     AND principal > 0 GROUP BY customer_name;",
