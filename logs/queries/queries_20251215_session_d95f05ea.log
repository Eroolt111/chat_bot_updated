  "original_query": "Энэ онд нийт хэдэн төгрөгийн зээл төлбөрийн хуваарийн дагуу төлөгдөх ёстой вэ",
  "tables_count": 1,
  "tables_selected": [
    "dbm.bcom_nrs_detail"
  ],
  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_version_cte AS (     SELECT         acnt_code,         MAX(nrs_version) AS max_ver     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code )  SELECT SUM(t.amount + t.int_amount) AS total_payment_due_mnt FROM     dbm.bcom_nrs_detail t INNER JOIN latest_version_cte lv     ON t.acnt_code = lv.acnt_code AND t.nrs_version = lv.max_ver WHERE     t.status = 'O'     AND t.cur_code = 'MNT'     AND t.schd_date >= TRUNC(SYSDATE, 'YYYY')     AND t.schd_date < ADD_MONTHS(TRUNC(SYSDATE, 'YYYY'), 12);",
  "result_count": 1,
  "final_answer": "Энэ онд зээл төлбөрийн хуваарийн дагуу нийт 130,176,210,657.12 төгрөг төлөгдөх ёстой байна."
}
