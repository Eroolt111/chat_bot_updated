  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_version_per_account AS (     SELECT         acnt_code,         MAX(nrs_version) AS current_version     FROM dbm.bcom_nrs_detail     GROUP BY acnt_code )  SELECT     'Энэ онд төлөгдөх нийт үндсэн зээлийн дүн' AS description,     SUM(t.amount) AS total_principal_due_mnt FROM dbm.bcom_nrs_detail t INNER JOIN latest_version_per_account lv     ON t.acnt_code = lv.acnt_code AND t.nrs_version = lv.current_version WHERE     t.status = 'O'     AND t.cur_code = 'MNT'     AND t.schd_date >= TRUNC(SYSDATE, 'YYYY')     AND t.schd_date < ADD_MONTHS(TRUNC(SYSDATE, 'YYYY'), 12);",
  "result_count": 1,
  "final_answer": "Энэ онд төлөгдөх нийт үндсэн зээлийн дүн: 87,490,429,827.69 төгрөг."
}
