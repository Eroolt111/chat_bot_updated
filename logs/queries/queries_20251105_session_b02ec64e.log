  "original_query": "хамгийн өндөр зээлийн үлдэгдэлтэй зээлийн мэдээлэл",
  "tables_count": 0,
  "tables_selected": [],
  "names_extracted_count": 20,
  "query_complexity": "SIMPLE",
  "was_decomposed": true,
  "final_sql": "WITH latest_open_loans AS (     SELECT         acnt_code,         customer_name,         acnt_name,         principal,         cur_code,         txn_date,         status,         principal * rate AS principal_in_mnt,         ROW_NUMBER() OVER (PARTITION BY acnt_code ORDER BY txn_date DESC) AS rn     FROM dbm.loan_balance_detail     WHERE status = 'O' AND principal IS NOT NULL AND rate IS NOT NULL )  SELECT     acnt_code,     customer_name,     acnt_name,     principal,     cur_code,     txn_date,     status,     principal_in_mnt FROM latest_open_loans WHERE rn = 1 ORDER BY principal_in_mnt DESC FETCH FIRST 1 ROW ONLY;",
  "result_count": 1,
  "final_answer": "Таны хүсэлтийн дагуу хамгийн өндөр зээлийн үлдэгдэлтэй зээлийн мэдээллийг хүргэж байна:  - Дансны код: MN780036003600008686 - Харилцагчийн нэр: ДЦС-4 ТӨХК - Дансны нэр: ДЦС-4 ТӨХК - Үлдэгдэл зээл: 253,309,397,578.54 төгрөг - Гүйлгээний огноо: 2025-09-12 - Төлөв: O - Үлдэгдэл төгрөгөөр: 253,309,397,578.54 төгрөг"
}
