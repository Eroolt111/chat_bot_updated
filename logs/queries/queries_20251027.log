  "was_decomposed": true,
  "final_sql": "WITH first_loan_per_account AS (     SELECT         acnt_code,         cust_code,         MAX(customer_name) KEEP (DENSE_RANK FIRST ORDER BY adv_date ASC, txn_date ASC) AS customer_name,         MIN(adv_date) AS first_adv_date     FROM dbm.loan_balance_detail     WHERE adv_date IS NOT NULL AND status = 'O'     GROUP BY acnt_code, cust_code ), first_loan_details AS (     SELECT         f.acnt_code,         f.cust_code,         f.customer_name,         l.approv_amount,         l.cur_code,         l.rate,         l.adv_date,         l.approv_amount * l.rate AS approv_amount_in_mnt     FROM first_loan_per_account f     JOIN dbm.loan_balance_detail l       ON f.acnt_code = l.acnt_code      AND l.adv_date = f.first_adv_date     WHERE l.status = 'O' ), first_loan_per_customer AS (     SELECT         cust_code,         MAX(customer_name) KEEP (DENSE_RANK FIRST ORDER BY adv_date ASC) AS customer_name,         MIN(adv_date) AS first_adv_date,         MAX(approv_amount) KEEP (DENSE_RANK FIRST ORDER BY adv_date ASC) AS approv_amount,         MAX(cur_code) KEEP (DENSE_RANK FIRST ORDER BY adv_date ASC) AS cur_code,         MAX(rate) KEEP (DENSE_RANK FIRST ORDER BY adv_date ASC) AS rate,         MAX(approv_amount_in_mnt) KEEP (DENSE_RANK FIRST ORDER BY adv_date ASC) AS approv_amount_in_mnt     FROM first_loan_details     GROUP BY cust_code ) SELECT     customer_name,     approv_amount,     cur_code,     rate,     approv_amount_in_mnt,     first_adv_date AS adv_date FROM first_loan_per_customer ORDER BY approv_amount_in_mnt DESC FETCH FIRST 3 ROWS ONLY;",
  "result_count": 3,
  "final_answer": "Таны хүсэлтийн дагуу Монгол Улсын Хөгжлийн Банкнаас хамгийн анх зээл авахдаа хамгийн өндөр дүнтэй авсан 3 зээлдэгчийн мэдээллийг хүргэж байна:  1.   - Зээлдэгчийн нэр: ДЦС-4 ТӨХК - Зээлийн дүн: 263,145,461,199.82 MNT - Валютын ханш: 1 - Төгрөгт хөрвүүлсэн дүн: 263,145,461,199.82 төгрөг - Зээл олгосон огноо: 2018-07-20  2.   - Зээлдэгчийн нэр: КЬЮ ЭС СИ ХХК - Зээлийн дүн: 71,300,000 USD - Валютын ханш: 3,594.42 - Төгрөгт хөрвүүлсэн дүн: 256,282,146,000 төгрөг - Зээл олгосон огноо: 2014-12-03  3.   - Зээлдэгчийн нэр: МОНГОЛ ГАЗРЫН ТОС БОЛОВСРУУЛАХ ҮЙЛДВЭР ТӨХХК - Зээлийн дүн: 250,000,000,000 MNT - Валютын ханш: 1 - Төгрөгт хөрвүүлсэн дүн: 250,000,000,000 төгрөг - Зээл олгосон огноо: 2018-04-26  Нэмэлт мэдээлэл хэрэгтэй бол дахин холбогдоно уу."
}
