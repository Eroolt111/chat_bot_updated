# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=
DB_PORT=1522
DB_NAME=
DB_USER=
DB_PASSWORD=

# ============================================================================
# LLM BACKEND SELECTION
# Options: "openai" | "ollama"
# ============================================================================
LLM_BACKEND=openai
AUX_LLM_BACKEND=openai
EMBEDDING_BACKEND=ollama

# ============================================================================
# OPENAI CONFIGURATION (required if LLM_BACKEND=openai)
# ============================================================================
OPENAI_API_KEY=
OPENAI_COMPLETION_MODEL=gpt-4.1
OPENAI_AUX_MODEL=gpt-4.1-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ============================================================================
# OLLAMA CONFIGURATION (required if LLM_BACKEND=ollama)
# ============================================================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=qwen3:8b-custom
OLLAMA_AUX_LLM_MODEL=qwen3:8b-custom
OLLAMA_EMBED_MODEL=toshk0/nomic-embed-text-v2-moe:Q6_K

# ============================================================================
# GEMINI CONFIGURATION (optional)
# ============================================================================
GEMINI_API_KEY=
GEMINI_LLM_MODEL=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
DEBUG=False
LOG_LEVEL=INFO

# ============================================================================
# TABLE CONFIGURATION
# TEST_MODE=True  → only use tables listed in TEST_TABLES
# TEST_MODE=False → use all tables in DB
# ============================================================================
TEST_MODE=True
TEST_TABLES=dbm.loan_balance_detail, dbm.bcom_nrs_detail, dbm.loan_txn, dbm.security_balance_detail, dbm.placement_balance_detail, dbm.borrowing_balance_detail, dbm.bac_balance_detail, dbm.casa_balance, dbm.fx_deal_detail, dbm.fx_swap_balance_detail, dbm.coll_balance_detail, dbm.gl_balance_detail

# ============================================================================
# PII MASKING
# ============================================================================
ENABLE_PII_MASKING=True
MASK_USER_INPUT=True
MASK_SAMPLE_ROWS=True

# ============================================================================
# PIPELINE BEHAVIOR
# ============================================================================
SEND_SAMPLE_ROWS=False
QUERY_ANALYZER_ENABLED=True
SELF_ERROR_CORRECTION_ENABLED=True
MAX_SQL_RETRY_ATTEMPTS=2
MAX_HISTORY_TURNS=3
